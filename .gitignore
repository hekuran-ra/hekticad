src-tauri/icons/android/
src-tauri/icons/ios/

# Tauri updater signing key — the PRIVATE half must never be committed.
# Store it as a GitHub Actions secret instead (TAURI_SIGNING_PRIVATE_KEY).
*.key
*.key.pub
